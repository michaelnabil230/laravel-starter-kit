{
    "$schema": "https://getcomposer.org/schema.json",
    "name": "michaelnabil230/laravel-starter-kit",
    "type": "project",
    "description": "An opinionated starter kit for building Laravel applications.",
    "keywords": [
        "laravel",
        "framework",
        "starter-kit"
    ],
    "license": "MIT",
    "require": {
        "php": "^8.4",
        "laravel-notification-channels/fcm": "^6.1.0",
        "inertiajs/inertia-laravel": "^3.1.0",
        "laravel/framework": "^13.12.0",
        "laravel/horizon": "^5.47.1",
        "laravel/pulse": "^1.7.3",
        "laravel/tinker": "^3.0.2",
        "maatwebsite/excel": "^3.1.69",
        "mcamara/laravel-localization": "^2.4.0",
        "pinkary-project/type-guard": "^0.1.0",
        "predis/predis": "^3.4.2",
        "sentry/sentry-laravel": "^4.25.1",
        "spatie/cpu-load-health-check": "^1.0.5",
        "spatie/laravel-activitylog": "^5.0.0",
        "spatie/laravel-backup": "^10.2.1",
        "spatie/laravel-health": "^1.40.0",
        "spatie/laravel-login-link": "^1.6.6",
        "spatie/laravel-medialibrary": "^11.23.0",
        "spatie/laravel-schedule-monitor": "^4.3.0",
        "spatie/laravel-translatable": "^6.14.1",
        "spatie/security-advisories-health-check": "^1.3.1",
        "staudenmeir/eloquent-json-relations": "^1.15",
        "tightenco/ziggy": "^2.6.2"
    },
    "require-dev": {
        "barryvdh/laravel-debugbar": "^4.2.8",
        "driftingly/rector-laravel": "^2.4.0",
        "fakerphp/faker": "^1.24.1",
        "larastan/larastan": "^3.10.0",
        "laravel/boost": "^2.4.8",
        "laravel/pint": "^1.29.1",
        "laravel/telescope": "^5.20.0",
        "mockery/mockery": "^1.6.12",
        "nunomaduro/collision": "^8.9.4",
        "pestphp/pest": "^4.7.0",
        "pestphp/pest-plugin-laravel": "^4.1.0",
        "pestphp/pest-plugin-type-coverage": "^4.0.4",
        "rector/rector": "^2.4.5"
    },
    "autoload": {
        "psr-4": {
            "App\\": "app/",
            "Database\\Factories\\": "database/factories/",
            "Database\\Seeders\\": "database/seeders/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "scripts": {
        "setup": [
            "composer install",
            "@php -r \"file_exists('.env') || copy('.env.example', '.env');\"",
            "@php artisan key:generate",
            "@php artisan migrate --force",
            "npm install --ignore-scripts",
            "npm run build"
        ],
        "dev": [
            "Composer\\Config::disableProcessTimeout",
            "npx concurrently -c \"#93c5fd,#c4b5fd,#fdba74\" \"php artisan serve\" \"php artisan queue:listen --tries=1 --timeout=0\" \"npm run dev\" --names=server,queue,vite --kill-others"
        ],
        "post-autoload-dump": [
            "Illuminate\\Foundation\\ComposerScripts::postAutoloadDump",
            "@php artisan package:discover --ansi"
        ],
        "post-update-cmd": [
            "@php artisan vendor:publish --tag=laravel-assets --ansi --force",
            "@php artisan clear --ansi",
            "@php artisan boost:update --ansi",
            "npx npm-check-updates -u"
        ],
        "post-root-package-install": [
            "@php -r \"file_exists('.env') || copy('.env.example', '.env');\""
        ],
        "pre-package-uninstall": [
            "Illuminate\\Foundation\\ComposerScripts::prePackageUninstall"
        ],
        "update:requirements": [
            "composer bump",
            "npx npm-check-updates -u"
        ],
        "format": "pint --parallel",
        "refactor": "rector",
        "test:type-coverage": "pest --type-coverage --min=98.9 --memory-limit=2G",
        "test:format": "pint --parallel --test",
        "test:unit": "pest --parallel --coverage --exactly=38.9",
        "test:types": "phpstan --memory-limit=2G",
        "test:refactor": "rector --dry-run",
        "test": [
            "@php artisan config:clear --ansi",
            "@php artisan test --parallel",
            "@test:type-coverage",
            "@test:format",
            "@test:types"
        ]
    },
    "extra": {
        "laravel": {
            "dont-discover": [
                "laravel/telescope"
            ]
        }
    },
    "config": {
        "optimize-autoloader": true,
        "preferred-install": "dist",
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true,
            "php-http/discovery": true
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}